# Local node identity so `bin/myapp rpc` can reach the booted daemon in the E2E
# test. The node name is overridable (MYAPP_NODE) so each test run uses a unique
# name and can't collide with a leaked daemon from a previous run. Long name
# (dotted host) requires RELEASE_DISTRIBUTION=name.
export RELEASE_DISTRIBUTION=name
export RELEASE_NODE=${MYAPP_NODE:-cayennex-myapp@127.0.0.1}
export RELEASE_COOKIE=${MYAPP_COOKIE:-cayennex-e2e-cookie}
